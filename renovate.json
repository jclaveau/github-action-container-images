{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ubuntu"],
      "groupName": "Ubuntu base image"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["docker"],
      "groupName": "Docker Engine"
    },
    {
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["docker/compose"],
      "groupName": "Docker Compose"
    },
    {
      "matchDatasources": ["npm"],
      "matchPackageNames": ["playwright"],
      "groupName": "Playwright"
    },
    {
      "matchDatasources": ["npm"],
      "matchPackageNames": ["pnpm"],
      "groupName": "pnpm"
    },
    {
      "matchDatasources": ["node-version"],
      "matchPackageNames": ["node"],
      "groupName": "Node.js"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^base/Dockerfile$"],
      "matchStrings": [
        "ARG DOCKER_VERSION=(?<currentValue>.*?)\\n"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["^base/Dockerfile$"],
      "matchStrings": [
        "ARG DOCKER_COMPOSE_VERSION=(?<currentValue>.*?)\\n"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "docker/compose",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^node/Dockerfile$"],
      "matchStrings": [
        "ARG NODE_VERSION=(?<currentValue>.*?)\\n"
      ],
      "datasourceTemplate": "node-version",
      "depNameTemplate": "node",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "fileMatch": ["^playwright/Dockerfile$"],
      "matchStrings": [
        "ARG PLAYWRIGHT_VERSION=(?<currentValue>.*?)\\n"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "playwright",
      "versioningTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["^pnpm/Dockerfile$"],
      "matchStrings": [
        "ARG PNPM_VERSION=(?<currentValue>.*?)\\n"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "pnpm",
      "versioningTemplate": "npm"
    }
  ],
  "schedule": [
    "before 6am on Monday"
  ],
  "automerge": false,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5
}
